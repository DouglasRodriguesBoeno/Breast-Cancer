# BreastCare AI — Frontend environment variables

# Local Spring Boot API URL
# Used by Next.js API routes to proxy requests to the backend.
BREASTCARE_API_URL=http://localhost:8080
BREASTCARE_API_BASE_URL=http://localhost:8080

# Production example:
# BREASTCARE_API_URL=https://your-breastcare-api-domain.com
# BREASTCARE_API_BASE_URL=https://breast-cancer-api-production.up.railway.app
